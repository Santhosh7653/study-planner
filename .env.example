# ────────────────────────────────────────────────────────────────────────
# STUDY PLANNER ENVIRONMENT VARIABLES
# ────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your actual values

# ────────────────────────────────────────────────────────────────────────
# SERVER CONFIG
# ────────────────────────────────────────────────────────────────────────

PORT=5000

# ────────────────────────────────────────────────────────────────────────
# EMAIL SERVICE (Gmail SMTP)
# ────────────────────────────────────────────────────────────────────────
# Option 1: Use Gmail
#   1. Enable 2-Factor Authentication on your Google account
#   2. Generate an App Password: https://myaccount.google.com/apppasswords
#   3. Use the generated 16-character password below

GMAIL_USER=your-email@gmail.com
GMAIL_PASS=your-16-character-app-password

# Optional: Custom SMTP server (if not using Gmail)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-password
# SMTP_FROM=noreply@example.com

# Email recipient (where reminders are sent)
RECIPIENT_EMAIL=your-email@gmail.com

# ────────────────────────────────────────────────────────────────────────
# FIREBASE CONFIG (for Firestore & Auth)
# ────────────────────────────────────────────────────────────────────────

VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# ────────────────────────────────────────────────────────────────────────
# GOOGLE OAUTH (for Google Calendar integration)
# ────────────────────────────────────────────────────────────────────────

VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ────────────────────────────────────────────────────────────────────────
# CRON SECRET (for scheduled tasks / serverless functions)
# ────────────────────────────────────────────────────────────────────────

CRON_SECRET=generate-a-random-secret-for-cron-jobs
