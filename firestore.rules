rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Tasks — only the owning user can read/write
    match /users/{userId}/tasks/{taskId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Profile — only the owning user can read; Cloud Functions write via admin SDK
    match /users/{userId}/profile/data {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // only writable by Cloud Functions (admin SDK)
    }
  }
}
